RewriteRule ^home\.css$ assets/css/home.css [L,NC]
RewriteRule ^style\.css$ assets/css/style.css [L,NC]
RewriteRule ^header\.css$ assets/css/header.css [L,NC]
RewriteRule ^footer\.css$ assets/css/footer.css [L,NC]
