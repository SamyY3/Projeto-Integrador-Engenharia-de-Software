RewriteRule ^tela-inicia\.html$ pages/tela-inicia.html [L,NC]
RewriteRule ^ecopontos\.html$ pages/ecopontos.html [L,NC]
RewriteRule ^perfil\.html$ pages/perfil.html [L,NC]
