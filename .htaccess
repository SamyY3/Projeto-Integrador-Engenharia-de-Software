Options -Indexes

DirectoryIndex pages/tela-inicia.html index.html

<FilesMatch "^(conexao\.config\.php|.*\.sql|composer\.(json|lock)|DEPLOY\.md)$">
  Require all denied
</FilesMatch>

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType text/javascript "access plus 7 days"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/jpeg "access plus 30 days"
  ExpiresByType image/webp "access plus 30 days"
  ExpiresByType image/svg+xml "access plus 30 days"
  ExpiresByType image/x-icon "access plus 30 days"
  ExpiresByType font/woff2 "access plus 30 days"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>
<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|png|jpe?g|webp|svg|ico|woff2)$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>

<IfModule mod_rewrite.c>
RewriteEngine On

RewriteRule ^Imagens/(.*)$ assets/images/$1 [L,NC]

RewriteRule ^login\.html$ auth/login.html [L,NC]
RewriteRule ^login\.php$ auth/login.php [L,NC]
RewriteRule ^cadastro\.html$ auth/cadastro.html [L,NC]
RewriteRule ^cadastro\.php$ auth/cadastro.php [L,NC]
RewriteRule ^recuperar\.html$ auth/recuperar.html [L,NC]
RewriteRule ^nova-senha\.html$ auth/nova-senha.html [L,NC]
RewriteRule ^verificacao\.html$ auth/verificacao.html [L,NC]
RewriteRule ^verificar-cadastro\.html$ auth/verificar-cadastro.html [L,NC]
RewriteRule ^verificar_cadastro\.php$ auth/verificar_cadastro.php [L,NC]
RewriteRule ^resetar_senha\.php$ auth/resetar_senha.php [L,NC]
RewriteRule ^resetar\.html$ auth/resetar.html [L,NC]
RewriteRule ^senha-criada\.html$ auth/senha-criada.html [L,NC]
RewriteRule ^login-temp\.html$ auth/login-temp.html [L,NC]

RewriteRule ^Login-ADM\.html$ admin/Login-ADM.html [L,NC]
RewriteRule ^Login-ADM\.php$ admin/Login-ADM.php [L,NC]
RewriteRule ^Login-ADM-Ecoponto\.html$ admin/Login-ADM-Ecoponto.html [L,NC]
RewriteRule ^Login-ADM-Ecoponto\.php$ admin/Login-ADM-Ecoponto.php [L,NC]
RewriteRule ^Home-ADM\.html$ admin/Home-ADM.html [L,NC]
